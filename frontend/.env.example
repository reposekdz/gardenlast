# Garden TVET Frontend - Environment Variables
# Copy this file to .env.local for local development or .env for production

# ============================================
# PRODUCTION (Render deployment)
# ============================================
# Set the API URL to point to your Render backend service
# Example: VITE_API_URL=https://garden-tvet-api.onrender.com

# API URL - Point to your deployed backend service
# Leave empty for local development (uses relative paths)
VITE_API_URL=https://garden-tvet-api.onrender.com

# Application Name (used in UI)
VITE_APP_NAME=Garden TVET School

# Environment
VITE_ENVIRONMENT=production
