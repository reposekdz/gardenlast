# Garden TVET Backend — Environment Variables
# Copy this file to .env and fill in your values

# ─── Database ────────────────────────────────────────────────
# Option A: individual params (local dev)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=garden_tvet

# Option B: full connection string (Aiven, Render, PlanetScale, etc.)
# DATABASE_URL=mysql://user:password@host:port/dbname

# ─── Security ────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET

# ─── Server ──────────────────────────────────────────────────
PORT=5000

# ─── Africa's Talking SMS ────────────────────────────────────
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=YOUR_API_KEY_HERE
# Optional: alphanumeric sender ID (must be registered with AT)
# AFRICASTALKING_SHORTCODE=GardenTVET

# ─── Email (SMTP) ────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Garden TVET School <noreply@gardentvet.rw>
